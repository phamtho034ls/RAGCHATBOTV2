# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=legal_bot
POSTGRES_PASSWORD=legal_bot_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=legal_chatbot

# ── Qdrant ─────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=law_documents
# QDRANT_API_KEY=         # Uncomment for cloud Qdrant

# ── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# ── LLM ────────────────────────────────────────────────────
DEFAULT_TEMPERATURE=0.5
MAX_TOKENS=4096

# ── Embedding ──────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIM=384

# ── HuggingFace (tránh warning rate-limit) ──────────────
HF_TOKEN=

# ── Reranker ───────────────────────────────────────────
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_DEVICE=cpu

# ── Retrieval ──────────────────────────────────────────
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5

# ── RAG (legacy v1) ───────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=4
