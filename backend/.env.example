# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=legal_bot
POSTGRES_PASSWORD=legal_bot_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=legal_chatbot

# ── Qdrant ─────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=law_documents
# Đổi model embedding (vd. 384→768): true = xóa collection cũ và tạo lại khi khởi động (mất vector cũ; chạy scripts/reembed_all.py)
# QDRANT_RECREATE_ON_DIM_MISMATCH=true
# QDRANT_API_KEY=         # Uncomment for cloud Qdrant

# ── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# ── LLM ────────────────────────────────────────────────────
DEFAULT_TEMPERATURE=0.5
MAX_TOKENS=4096
# Routing cán bộ xã vs RAG: ngưỡng margin cosine (prototype); LLM phân xử khi |s_c-s_l| < margin
# COMMUNE_ROUTE_MARGIN=0.10
# COMMUNE_ROUTE_ARBITER_MODEL=gpt-4o-mini
# COMMUNE_ROUTE_ARBITER_MAX_TOKENS=120

# Phân loại câu hỏi JSON (checklist vs nội dung pháp lý, legal guard Copilot) — tắt = chỉ regex + bundle cũ
# QUERY_UTTERANCE_CLASSIFIER_ENABLED=true
# QUERY_UTTERANCE_CLASSIFIER_MODEL=gpt-4o-mini
# QUERY_UTTERANCE_CLASSIFIER_MAX_TOKENS=320
# QUERY_UTTERANCE_MERGE_MIN_CONFIDENCE=0.35
# QUERY_UTTERANCE_OOS_MIN_CONFIDENCE=0.52

# ── Embedding (V3: vietnamese-sbert 768-dim, max 512 tokens) ─
EMBEDDING_MODEL=keepitreal/vietnamese-sbert
EMBEDDING_FALLBACK_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_LENGTH=512
EMBEDDING_DIM=768

# Intent PhoBERT (backend/app/intent_model) — tắt nếu không cài transformers / không có weights
# INTENT_MODEL_ENABLED=true
# INTENT_MODEL_DIR=
# INTENT_MODEL_MIN_CONFIDENCE=0.50
# INTENT_MODEL_MAX_LENGTH=256
# INTENT_MODEL_DEVICE=cpu
# File YAML: structural fallback + routing (checklist/multi-doc) + prototype_sentences
# INTENT_PATTERNS_YAML=

# ── HuggingFace (tránh warning rate-limit) ──────────────
HF_TOKEN=

# ── Reranker (V3: v2-m3 đa ngôn ngữ; fallback base) ─────
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_FALLBACK_MODEL=BAAI/bge-reranker-base
RERANKER_DEVICE=cpu
RERANKER_BATCH_SIZE=16

# ── Validation (V3) ───────────────────────────────────
ANSWER_VALIDATION_THRESHOLD=0.40

# ── Retrieval ──────────────────────────────────────────
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5

# ── RAG (legacy v1) ───────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=4
